import requests
import time
from .__helpers import send_data

def init(doku_url, token):
    # original_chat_create = openai.ChatCompletion.create
    original_request = requests.post

    def patched_requests_post(url, *args, **kwargs):
        # Define the pattern you want to match
        url_pattern = "https://api-inference.huggingface.co/models/gpt2"
        
        if url == "https://api-inference.huggingface.co/models/gpt2": 
            start_time = time.time()
            response = original_request(url, *args, **kwargs)
            end_time = time.time()
            duration = end_time - start_time

            model = url[len(url_pattern):]
            prompt = kwargs.get('json').get('inputs')

            data = {
                "source": "python",
                "endpoint": "huggingface.api-inference",
                "requestDuration": duration,
                "model": model,
                "prompt": prompt,
                "response": response.json()[0].get('generated_text', '')
            }
        
            send_data(data, doku_url, token)

            return response
        else:
            return original_request(url, *args, **kwargs)

    # openai.ChatCompletion.create = patched_chat_create
    requests.post = patched_requests_post
